# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# typescript
*.tsbuildinfo
next-env.d.ts

# local tooling / artifacts
/.claude
/.git-corrupt-bak
*.dmg
.vercel

# generated audit reports (the audit.js / website-audit.sh tooling is tracked)
audit-report.*.md

# raw DOL OFLC LCA disclosure files — large (100-600 MB), never committed.
# Only the rolled-up data/h1b/sponsors.csv produced by data/h1b/etl.py is tracked.
data/h1b/*.xlsx

# Raw Search Console exports (seo:gsc-import input). Private performance data
# for a site we own — it is nobody else's business and must never ship to the
# public bundle. The normalized aggregate in reports/ is derived from these and
# is also untracked. Drop the unzipped CSVs in seo-data/gsc/YYYY-MM-DD/.
# The README is the one tracked file — it documents where to put the exports.
/seo-data/*
!/seo-data/README.md

# Generated SEO reports (route inventory, audit findings, opportunity scoring).
# Regenerate with `npm run seo:inventory` / `seo:audit` / `seo:opportunities`.
/reports/
