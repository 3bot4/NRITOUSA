# Copy to .env.local for local development, and set the same vars in the
# Vercel dashboard (Project → Settings → Environment Variables) for production.

# --- Contributor submission form (/contribute → /api/contribute) ----------
# Brevo transactional email API key — https://app.brevo.com → SMTP & API →
# API Keys. Use the normal API key, not the MCP key.
BREVO_API_KEY=

# Where contributor submissions are emailed (your inbox).
CONTRIBUTE_EMAIL_TO=you@example.com

# Verified Brevo sender email + display name.
CONTRIBUTE_EMAIL_FROM=contribute@nritousa.com
CONTRIBUTE_EMAIL_FROM_NAME=NRI to USA

# Optional fallback reply-to. Normally replies go to the submitter's email.
CONTRIBUTE_REPLY_TO=

# --- Newsletter signup (Newsletter form → /api/newsletter) -----------------
# Reuses BREVO_API_KEY above. Numeric Brevo list id to subscribe people to.
# Defaults to 5 ("Newsletter Subscribers") if unset.
BREVO_NEWSLETTER_LIST_ID=5

# --- Lead magnet (Free Immigrant Wealth Guide → /api/lead-magnet) ----------
# Reuses BREVO_API_KEY and BREVO_NEWSLETTER_LIST_ID above. Optional extra
# numeric Brevo list id so lead-magnet signups can be segmented separately.
# Leave unset to only use BREVO_NEWSLETTER_LIST_ID.
BREVO_LEAD_MAGNET_LIST_ID=

# --- Return-to-India Playbook lead magnet -----------------------------------
# (ReturnToIndiaLeadMagnetCard → /api/lead-magnet/return-to-india-playbook)
# Reuses BREVO_API_KEY above. Numeric Brevo list id for the dedicated
# "NRItoUSA - Return to India Playbook" list. Falls back to
# BREVO_LEAD_MAGNET_LIST_ID, then to BREVO_NEWSLETTER_LIST_ID.
BREVO_RETURN_TO_INDIA_LIST_ID=

# Verified Brevo sender for the PDF delivery email. Falls back to
# CONTRIBUTE_EMAIL_FROM / CONTRIBUTE_EMAIL_FROM_NAME above if unset.
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=NRI to USA
