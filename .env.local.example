# Supabase — copy this file to .env.local and fill in the values from your
# Supabase project (Project Settings → API). Never commit .env.local.

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret — NEVER expose this to the browser / client code.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: existing Google Analytics measurement id (already used by the site)
# NEXT_PUBLIC_GA_ID=
